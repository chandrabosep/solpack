# Solana cluster: "devnet" | "mainnet-beta"
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# Override RPC endpoint (optional). Falls back to clusterApiUrl().
NEXT_PUBLIC_SOLANA_RPC_URL=

# USDC mint on the chosen cluster.
# Devnet USDC: 4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
# Mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Public app URL (used in preinstall config snippets shown in the dashboard).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LI.FI integrator key — register at https://portal.li.fi to track usage,
# get fee discounts, and remove unbranded mode. Optional.
NEXT_PUBLIC_LIFI_INTEGRATOR=solpack

# Solana mainnet RPC used by the LI.FI verification endpoint. LI.FI is
# mainnet-only, so cross-chain payments must be verified against mainnet
# regardless of the project's configured cluster. Falls back to the
# public clusterApiUrl("mainnet-beta") if unset (rate-limited).
SOLANA_MAINNET_RPC_URL=

